rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default: Deny all direct client reads/writes.
    // The only way a client can view a clip/snapshot is via a V4 Signed URL 
    // generated by the backend API.
    match /{allPaths=**} {
      allow read, write: if false; 
    }
    
    // (Optional Future Provision): If you ever want authenticated users to directly
    // download their org's files using the Firebase Client SDK instead of Signed URLs:
    /*
    match /clips/{orgId}/{incidentId}/clip.mp4 {
      allow read: if request.auth != null && request.auth.token.orgId == orgId;
    }
    match /snapshots/{orgId}/{incidentId}.jpg {
      allow read: if request.auth != null && request.auth.token.orgId == orgId;
    }
    */
  }
}
